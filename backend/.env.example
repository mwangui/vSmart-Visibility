# ─────────────────────────── Auth (v2.1 simplified) ───────────────────────────
# Single shared password gate. No User table. Case-insensitive comparison.
APP_PASSWORD=demo
APP_PASSWORD_CASE_INSENSITIVE=true
# JWT_SECRET_KEY — generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-bytes
JWT_EXPIRE_DAYS=7
COOKIE_NAME=vsmart_session
COOKIE_SECURE=false  # set true behind HTTPS
COOKIE_SAMESITE=lax

# ─────────────────────────── Anthropic ───────────────────────────────────────
ANTHROPIC_API_KEY=
# Model IDs are loaded from .env — never hardcode them in source.
# Verify currently available IDs at https://docs.claude.com/en/docs/about-claude/models
# before running. Suggested role mapping (fill in):
#   CHAT_MODEL    → premium streaming answer model
#   ROUTER_MODEL  → fast/cheap JSON-output model for brief routing
#   VISION_MODEL  → vision-capable model for chart/diagram extraction
#   BRIEF_MODEL   → mid-tier model for one-off brief generation
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BRIEF_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# ─────────────────────────── RAG ─────────────────────────────────────────────
# Path is resolved relative to repo root if not absolute.
RAG_DOC_DIR=../RAG-Doc
ROUTER_CONFIDENCE_THRESHOLD=0.5
ROUTER_MAX_FILES=5
ROUTER_CANDIDATE_BRIEFS=30
CHUNK_FALLBACK_TOP_K=12
CONVERSATION_CONTEXT_TURNS=6

# ─────────────────────────── Embeddings ──────────────────────────────────────
# Multilingual is REQUIRED — corpus contains Traditional Chinese.
# Recommended (in order): BAAI/bge-m3, sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu  # cpu | cuda | mps

# ─────────────────────────── Ingest ──────────────────────────────────────────
INGEST_CONCURRENCY=2
INGEST_DEBOUNCE_MS=2000
INGEST_RESCAN_INTERVAL_S=300
INGEST_WATCH_RECURSIVE=false
VLM_IMAGE_AREA_THRESHOLD=0.30
VLM_TEXT_WORD_THRESHOLD=100
VLM_CONCURRENCY=2

# ─────────────────────────── DB ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/app.sqlite

# ─────────────────────────── Server / CORS ───────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
